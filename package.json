{
  "name": "futbolclub",
  "version": "1.0.0",
  "private": true,
  "description": "Aplicación web para crear alineaciones, gestionar planteles y organizar fútbol amateur.",
  "license": "MIT",
  "scripts": {
    "serve": "http-server -p 8765 -c-1 .",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:edge": "playwright test --project=msedge",
    "screenshots": "playwright test tests/screenshots.spec.js --reporter=list",
    "screenshots:mobile": "playwright test tests/screenshots-mobile.spec.js --reporter=list"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "http-server": "^14.1.1"
  }
}
